# Database
# Vercel Postgres auto-sets these when the "vote-to-feed" database is linked to your project.
# For local dev with Docker:
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5434/petvoter?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@localhost:5434/petvoter"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth (optional — can also be set in Admin > Settings)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (optional — can also be set in Admin > Settings)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Stripe (optional — can also be set in Admin > Settings)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (optional — can also be set in Admin > Settings > Email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Vote to Feed <noreply@votetofeed.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Cron Secret (optional — secures the free vote reset endpoint)
CRON_SECRET=""
