# Database
# For local dev with Docker:
DATABASE_URL="postgresql://user:password@localhost:5434/petvoter"
DIRECT_URL="postgresql://user:password@localhost:5434/petvoter"
# For Vercel Postgres: set both via the Vercel dashboard.
# DATABASE_URL will be the pooled connection, DIRECT_URL will be the direct connection.

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (optional)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Stripe (optional — can also be set in Admin > Settings)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (email — can also be set in Admin > Settings > Email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Vote to Feed <noreply@votetofeed.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Cron Secret (optional — secures the free vote reset endpoint)
CRON_SECRET=""
