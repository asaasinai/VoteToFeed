# Database
DATABASE_URL="postgresql://user:password@localhost:5432/petvoter"
DIRECT_URL="postgresql://user:password@localhost:5432/petvoter"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth (optional)
# Preferred: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# Backwards-compatible fallback: CLIENT_ID / CLIENT_SECRET
# Optional explicit callback override if Google is configured with a fixed redirect URI
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
CLIENT_ID=""
CLIENT_SECRET=""
REDIRECT_URI=""

# Facebook OAuth (optional)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Stripe (optional — can also be set in Admin > Settings)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email providers
RESEND_API_KEY=""
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@votetofeed.com"

# Anthropic
ANTHROPIC_API_KEY=""

# Google / Gemini image generation
GEMINI_API_KEY=""
GOOGLE_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="https://votetofeed.com"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Client analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_META_PIXEL_ID="2009139989998970"

# Internal analytics reporting baseline (optional)
# Example: 2026-03-19T15:15:00Z
INTERNAL_ANALYTICS_REPORTING_START_AT=""

# PostHog admin analytics (server-side query API)
POSTHOG_HOST="https://us.posthog.com"
POSTHOG_PROJECT_ID=""
POSTHOG_PERSONAL_API_KEY=""

# Cron Secret
CRON_SECRET=""
