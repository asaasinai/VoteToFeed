generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTH ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(USER)
  city          String?
  state         String?
  country       String?
  zipCode       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Free votes
  freeVotesRemaining Int      @default(5)
  lastFreeVoteReset  DateTime @default(now())
  votingStreak       Int      @default(0)
  lastVotedWeek      String?

  // Paid votes
  paidVoteBalance Int @default(0)

  // Email tracking
  lastFreeVoteReminderWeek String? // e.g. "2026-W15" — prevents double-sending reminder

  accounts       Account[]
  sessions       Session[]
  pets           Pet[]
  votes          Vote[]
  comments       Comment[]
  scheduledComments ScheduledComment[] @relation("ScheduledCommentEngagementAccount")
  scheduledVotes    ScheduledVote[]    @relation("ScheduledVoteSeedAccount")
  purchases      Purchase[]
  productOrders  ProductOrder[]
  notifications  UserNotificationPrefs?
  shelterPosts   ShelterPost[]
  passwordResetTokens PasswordResetToken[]
  chatConversations ChatConversation[]
  commentLikes  CommentLike[]

  // Social
  followers           Follow[]          @relation("FollowTarget")
  following           Follow[]          @relation("FollowSource")
  badges              UserBadge[]
  posts               UserPost[]
  postLikes           PostLike[]
  postComments        PostComment[]
  postCommentLikes    PostCommentLike[]
  followBonusLogs     FollowBonusLog[]
  nominationsSent     Nomination[]      @relation("NominationsSent")
  contestEmailLogs    ContestEmailLog[]
  nominationSendJobs  NominationSendJob[] @relation("NominationSendJobs")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

model UserNotificationPrefs {
  id                  String  @id @default(cuid())
  userId              String  @unique
  voteAlerts          Boolean @default(true)
  commentAlerts       Boolean @default(true)
  designAlerts        Boolean @default(true)
  weeklyDigest        Boolean @default(true)
  freeVoteReminder    Boolean @default(true)
  contestAlerts       Boolean @default(true)
  maxVoteAlertsPerDay Int     @default(5)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Cooldown tracker so we batch vote alerts — only 1 email per pet per 6 hours
model VoteEmailCooldown {
  id          String   @id @default(cuid())
  petId       String
  ownerId     String
  lastSentAt  DateTime @default(now())
  pendingCount Int     @default(0)

  @@unique([petId, ownerId])
  @@index([petId])
  @@index([ownerId])
}

// ─── PETS ────────────────────────────────────────────────

model Pet {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(60)
  type        PetType
  breed       String?
  bio         String?  @db.VarChar(255)
  ownerName   String
  ownerFirstName String?
  ownerLastName  String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  country     String?  @default("US")
  photos      String[] // Array of photo URLs
  tags        String[]
  isActive    Boolean  @default(true)
  optInDesigns Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  votes          Vote[]
  anonymousVotes AnonymousVote[]
  comments       Comment[]
  scheduledComments ScheduledComment[]
  scheduledVotes    ScheduledVote[]
  contestEntries ContestEntry[]
  productDesigns ProductDesign[]
  weeklyStats    PetWeeklyStats[]

  @@index([type, isActive])
  @@index([state])
  @@index([breed])
  @@index([createdAt])
}

enum PetType {
  DOG
  CAT
  OTHER
}

// ─── VOTING ──────────────────────────────────────────────

model Vote {
  id        String   @id @default(cuid())
  petId     String
  userId    String
  voteType  VoteType
  quantity  Int      @default(1)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  contestWeek String // Format: "2026-W02" for weekly tracking

  pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([petId, contestWeek])
  @@index([userId, contestWeek])
  @@index([createdAt])
  @@index([contestWeek])
}

model AnonymousVote {
  id          String   @id @default(cuid())
  petId       String
  ipAddress   String
  userAgent   String?
  contestWeek String
  createdAt   DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([ipAddress, createdAt])
  @@index([contestWeek])
  @@index([petId, contestWeek])
}

enum VoteType {
  FREE
  PAID
}

// ─── PURCHASES ───────────────────────────────────────────

model Purchase {
  id              String        @id @default(cuid())
  userId          String
  packageTier     PackageTier
  votes           Int
  amount          Int           // cents
  currency        String        @default("usd")
  stripePaymentId String?       @unique
  stripeSessionId String?       @unique
  status          PaymentStatus @default(PENDING)
  mealsProvided   Float         @default(0)
  mealRateAtPurchase Float      @default(10.0)
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum PackageTier {
  STARTER
  FRIEND
  SUPPORTER
  CHAMPION
  HERO
  LEGEND
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── CONTESTS ────────────────────────────────────────────

model Contest {
  id          String      @id @default(cuid())
  name        String
  type        ContestType
  petType     PetType
  state       String?     // For regional contests
  weekId      String?     // "2026-W02" (optional — long-running contests don't need this)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean     @default(true)
  isFeatured  Boolean     @default(false)
  description String?     @db.Text
  rules       String?     @db.Text   // Contest-specific rules or instructions
  coverImage  String?     // URL for contest banner/image
  entryFee    Int         @default(0) // cents, 0 = free
  maxEntries  Int?        // null = unlimited
  prizeDescription String? @db.Text  // Human-readable summary of prizes
  sponsorName  String?
  sponsorLogo  String?
  sponsorUrl   String?
  isRecurring       Boolean  @default(false)
  recurringInterval String?  // 'weekly', 'biweekly', 'monthly'
  recurringCounter  Int      @default(0) // incremented each recurrence
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  entries          ContestEntry[]
  prizes           Prize[]
  shelterPosts     ShelterPost[]
  nominations      Nomination[]
  contestEmailLogs ContestEmailLog[]
  nominationSendJobs NominationSendJob[]

  @@index([isActive, petType])
  @@index([isActive, endDate])
  @@index([isRecurring, endDate])
  @@index([weekId])
}

enum ContestType {
  NATIONAL
  STATE
  SEASONAL
  BREED
  CHARITY
  CALENDAR
}

model ContestEntry {
  id        String   @id @default(cuid())
  contestId String
  petId     String
  createdAt DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  pet     Pet     @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([contestId, petId])
}

model ContestEmailLog {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  emailType String
  sentAt    DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId, emailType])
  @@index([contestId])
  @@index([userId])
}

model CustomEmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  html      String   @db.Text
  prompt    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ReEntryToken {
  id            String   @id @default(cuid())
  token         String   @unique @default(cuid())
  userId        String
  petId         String
  fromContestId String
  toContestId   String
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// ─── PRIZES ──────────────────────────────────────────────

model Prize {
  id          String    @id @default(cuid())
  contestId   String
  placement   Int       // 1, 2, 3, etc.
  title       String
  description String?   @db.Text
  value       Int       // cents
  items       String[]  // List of prize items
  status      PrizeStatus @default(PENDING)
  winnerId    String?   // Pet ID
  awardedAt   DateTime?
  fulfilledAt DateTime?
  createdAt   DateTime  @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, placement])
}

enum PrizeStatus {
  PENDING
  AWARDED
  SHIPPED
  FULFILLED
}

// ─── PET WEEKLY STATS (Materialized for performance) ────

model PetWeeklyStats {
  id          String @id @default(cuid())
  petId       String
  weekId      String // "2026-W02"
  totalVotes  Int    @default(0)
  freeVotes   Int    @default(0)
  paidVotes   Int    @default(0)
  rank        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([petId, weekId])
  @@index([weekId, totalVotes(sort: Desc)])
  @@index([petId])
}

// ─── COMMENTS ────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  text      String   @db.VarChar(255)
  petId     String
  userId    String
  parentId  String?
  createdAt DateTime @default(now())

  pet      Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")
  flags    FlaggedComment[]
  likes    CommentLike[]

  @@index([petId, createdAt])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}

model ScheduledComment {
  id                  String                 @id @default(cuid())
  petId               String
  engagementAccountId String
  scheduledFor        DateTime
  commentText         String                 @db.VarChar(255)
  status              ScheduledCommentStatus @default(PENDING)
  processedAt         DateTime?
  errorMessage        String?                @db.VarChar(500)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  pet               Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  engagementAccount User @relation("ScheduledCommentEngagementAccount", fields: [engagementAccountId], references: [id], onDelete: Cascade)

  @@index([scheduledFor, status])
  @@index([petId])
  @@index([engagementAccountId])
}

enum ScheduledCommentStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

// ─── SCHEDULED VOTES (Demo Account Auto-Voting) ─────────

model ScheduledVote {
  id            String              @id @default(cuid())
  petId         String
  seedAccountId String
  votesAmount   Int                 @default(1)
  weekId        String
  scheduledFor  DateTime
  status        ScheduledVoteStatus @default(PENDING)
  processedAt   DateTime?
  errorMessage  String?             @db.VarChar(500)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  pet         Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  seedAccount User @relation("ScheduledVoteSeedAccount", fields: [seedAccountId], references: [id], onDelete: Cascade)

  @@index([scheduledFor, status])
  @@index([petId])
  @@index([seedAccountId])
}

enum ScheduledVoteStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

// ─── AI PRODUCT DESIGNS ──────────────────────────────────

model ProductDesign {
  id          String        @id @default(cuid())
  petId       String
  theme       String        // "astronaut", "superhero", etc.
  aiImageUrl  String        // Generated AI image URL
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  pet      Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
  mockups  ProductMockup[]

  @@index([petId])
}

model ProductMockup {
  id            String       @id @default(cuid())
  designId      String
  productType   ProductType
  mockupUrl     String
  price         Int          // cents
  costBasis     Int          // cents
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  design ProductDesign @relation(fields: [designId], references: [id], onDelete: Cascade)
  orders ProductOrder[]

  @@index([designId])
}

enum ProductType {
  MUG
  TSHIRT
  HOODIE
  PHONE_CASE
  PILLOW
  BLANKET
  CALENDAR
  POSTER
  TOTE_BAG
  HAT
}

model ProductOrder {
  id              String      @id @default(cuid())
  userId          String
  mockupId        String
  quantity        Int         @default(1)
  size            String?
  totalAmount     Int         // cents
  stripePaymentId String?
  status          OrderStatus @default(PENDING)
  trackingNumber  String?
  shippingAddress String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockup ProductMockup @relation(fields: [mockupId], references: [id])

  @@index([userId])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── ADMIN SETTINGS ──────────────────────────────────────

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  changelog AdminSettingLog[]
}

model AdminSettingLog {
  id        String   @id @default(cuid())
  settingId String
  oldValue  String
  newValue  String
  changedBy String
  createdAt DateTime @default(now())

  setting AdminSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@index([settingId, createdAt])
}

// ─── SHELTER PARTNERS ────────────────────────────────────

model ShelterPartner {
  id          String  @id @default(cuid())
  name        String
  logoUrl     String?
  website     String?
  description String? @db.Text
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
}

// ─── BREED DIRECTORY ─────────────────────────────────────

model Breed {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  petType      PetType
  origin       String?
  description  String? @db.Text
  temperament  String?
  size         String? // Small, Medium, Large
  lifespan     String?
  imageUrl     String?
  createdAt    DateTime @default(now())

  @@index([petType])
}

// ─── SHELTER IMPACT POSTS (Instagram-style feed) ────

model ShelterPost {
  id            String          @id @default(cuid())
  title         String?
  featuredImage String?
  content       String?         @db.Text
  photos        String[]        // Gallery photo URLs
  caption       String?         @db.Text
  videoUrl      String?
  tags          String[]
  type          ShelterPostType @default(UPDATE)
  location      String?         // Shelter name or location
  contestId     String?
  contest       Contest?        @relation(fields: [contestId], references: [id], onDelete: SetNull)
  authorId      String
  author        User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  isPublished   Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt

  @@index([isPublished, createdAt])
  @@index([type])
}

enum ShelterPostType {
  UPDATE
  STORY
  ANNOUNCEMENT
  GALLERY
}

// ─── USER POSTS ──────────────────────────────────────────

model UserPost {
  id        String        @id @default(cuid())
  content   String        @db.Text
  imageUrl  String?
  createdAt DateTime      @default(now())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     PostLike[]
  comments  PostComment[]

  @@index([userId, createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      UserPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model PostComment {
  id        String              @id @default(cuid())
  postId    String
  post      UserPost            @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String              @db.Text
  createdAt DateTime            @default(now())
  likes     PostCommentLike[]

  @@index([postId, createdAt])
}

model PostCommentLike {
  id        String      @id @default(cuid())
  commentId String
  comment   PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

// ─── API KEYS ────────────────────────────────────────────

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  prefix    String   // first 8 chars for display
  isActive  Boolean  @default(true)
  lastUsedAt DateTime?
  usageCount Int     @default(0)
  createdBy String
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([key])
  @@index([isActive])
}

// ─── COMMENT MODERATION ──────────────────────────────────

model FlaggedComment {
  id        String   @id @default(cuid())
  commentId String
  reason    String   // "profanity", "url", "manual"
  matchedWords String[] // what triggered the flag
  status    FlagStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

// ─── NOMINATIONS ──────────────────────────────────

model Nomination {
  id          String           @id @default(cuid())
  email       String
  name        String
  petName     String?
  contestId   String
  status      NominationStatus @default(PENDING)
  sentAt      DateTime?
  createdAt   DateTime         @default(now())
  sentById    String

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  sentBy  User    @relation("NominationsSent", fields: [sentById], references: [id], onDelete: Cascade)

  @@unique([email, contestId])
  @@index([email])
  @@index([contestId])
  @@index([status])
}

enum NominationStatus {
  PENDING
  SENT
  SIGNED_UP
  ENTERED
}

// Tracks active/paused/stopped bulk nomination send jobs so progress survives page refresh
model NominationSendJob {
  id           String   @id @default(cuid())
  contestId    String
  contestName  String
  recipients   Json     // Array<{ email, name, petName? }>
  total        Int
  sent         Int      @default(0)
  failed       Int      @default(0)
  status       String   @default("running") // "running" | "paused" | "stopped" | "done"
  startedAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  startedById  String

  contest    Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  startedBy  User    @relation("NominationSendJobs", fields: [startedById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([startedById])
}

enum FlagStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── AUTO ENGAGEMENT LOG ─────────────────────────────────

model EngagementLog {
  id            String   @id @default(cuid())
  targetUserId  String   // new user who got engagement
  seedAccountId String   // seed account that engaged
  petId         String   // pet that was engaged with
  action        String   // "like" or "comment"
  commentText   String?  // the comment if action=comment
  createdAt     DateTime @default(now())

  @@index([targetUserId, createdAt])
  @@index([seedAccountId])
}

// ─── BOOKINGS ────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  name          String
  email         String
  phone         String?
  purpose       String?
  notes         String?       @db.Text
  startTime     DateTime
  endTime       DateTime
  status        BookingStatus @default(CONFIRMED)
  googleEventId String?
  createdAt     DateTime      @default(now())

  @@index([startTime])
  @@index([email])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// ─── AI CHAT SUPPORT ─────────────────────────────────────

model ChatConversation {
  id          String   @id @default(cuid())
  sessionId   String   @unique // browser session ID
  userId      String?  // null for anonymous visitors
  userName    String?  // visitor-provided name or user name
  userEmail   String?
  status      ChatStatus @default(OPEN)
  lastMessage String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([status, updatedAt])
  @@index([userId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           ChatRole // USER, ASSISTANT, or ADMIN
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum ChatStatus {
  OPEN
  CLOSED
}

enum ChatRole {
  USER
  ASSISTANT
  ADMIN
}

// ─── SOCIAL: FOLLOWS ─────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String   // the user who follows
  followingId String   // the user being followed
  createdAt   DateTime @default(now())

  follower  User @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FollowBonusLog {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower User @relation(fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ─── BADGES ──────────────────────────────────────────────

model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String   // emoji or icon name
  category    BadgeCategory
  threshold   Int      @default(0) // the number needed to earn it
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

enum BadgeCategory {
  VOTING      // based on votes cast
  SOCIAL      // based on followers/following
  PETS        // based on pets registered
  STREAK      // based on voting streaks
  COMMUNITY   // special community badges
}
