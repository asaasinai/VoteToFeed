generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AdminSetting {
  id              String            @id @default(cuid())
  key             String            @unique
  value           String
  updatedBy       String?
  updatedAt       DateTime
  createdAt       DateTime          @default(now())
  AdminSettingLog AdminSettingLog[]
}

model AdminSettingLog {
  id           String       @id @default(cuid())
  settingId    String
  oldValue     String
  newValue     String
  changedBy    String
  createdAt    DateTime     @default(now())
  AdminSetting AdminSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@index([settingId, createdAt])
}

model AnonymousVote {
  id          String   @id @default(cuid())
  petId       String
  ipAddress   String
  userAgent   String?
  contestWeek String
  createdAt   DateTime @default(now())
  Pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([contestWeek])
  @@index([ipAddress, createdAt])
  @@index([petId, contestWeek])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  prefix     String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  usageCount Int       @default(0)
  createdBy  String
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([isActive])
  @@index([key])
}

model Badge {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String
  icon        String
  category    BadgeCategory
  threshold   Int           @default(0)
  createdAt   DateTime      @default(now())
  UserBadge   UserBadge[]
}

model Booking {
  id            String        @id @default(cuid())
  name          String
  email         String
  phone         String?
  purpose       String?
  notes         String?
  startTime     DateTime
  endTime       DateTime
  status        BookingStatus @default(CONFIRMED)
  googleEventId String?
  createdAt     DateTime      @default(now())

  @@index([email])
  @@index([startTime])
}

model Breed {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  petType     PetType
  origin      String?
  description String?
  temperament String?
  size        String?
  lifespan    String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  @@index([petType])
}

model ChatConversation {
  id              String        @id @default(cuid())
  sessionId       String        @unique
  userId          String?
  userName        String?
  userEmail       String?
  status          ChatStatus    @default(OPEN)
  lastMessage     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  aiPaused        Boolean       @default(false)
  isTicket        Boolean       @default(false)
  ticketCreatedAt DateTime?
  ticketProblem   String?
  ticketStage     String?
  User            User?         @relation(fields: [userId], references: [id])
  ChatMessage     ChatMessage[]

  @@index([isTicket, ticketStage])
  @@index([status, updatedAt])
  @@index([userId])
}

model ChatMessage {
  id               String           @id @default(cuid())
  conversationId   String
  role             ChatRole
  content          String
  createdAt        DateTime         @default(now())
  ChatConversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Comment {
  id             String           @id @default(cuid())
  text           String           @db.VarChar(255)
  petId          String
  userId         String
  parentId       String?
  createdAt      DateTime         @default(now())
  Comment        Comment?         @relation("CommentToComment", fields: [parentId], references: [id])
  other_Comment  Comment[]        @relation("CommentToComment")
  Pet            Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
  User           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  CommentLike    CommentLike[]
  FlaggedComment FlaggedComment[]

  @@index([petId, createdAt])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  Comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}

model Contest {
  id                String              @id @default(cuid())
  name              String
  type              ContestType
  petType           PetType
  state             String?
  weekId            String?
  startDate         DateTime
  endDate           DateTime
  isActive          Boolean             @default(true)
  isFeatured        Boolean             @default(false)
  description       String?
  rules             String?
  coverImage        String?
  entryFee          Int                 @default(0)
  maxEntries        Int?
  prizeDescription  String?
  sponsorName       String?
  sponsorLogo       String?
  sponsorUrl        String?
  isRecurring       Boolean             @default(false)
  recurringInterval String?
  recurringCounter  Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @default(now())
  isStoryteller     Boolean             @default(false)
  currentPhase      String              @default("OPEN")
  finaleStartDate   DateTime?
  round2StartDate   DateTime?
  round3StartDate   DateTime?
  top100CutSize     Int                 @default(100)
  top25CutSize      Int                 @default(25)
  top5CutSize       Int                 @default(5)
  ContestEmailLog   ContestEmailLog[]
  ContestEntry      ContestEntry[]
  Nomination        Nomination[]
  NominationSendJob NominationSendJob[]
  Prize             Prize[]
  ShelterPost       ShelterPost[]

  @@index([isActive, endDate])
  @@index([isActive, petType])
  @@index([isRecurring, endDate])
  @@index([weekId])
}

model ContestEmailLog {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  emailType String
  sentAt    DateTime @default(now())
  Contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId, emailType])
  @@index([contestId])
  @@index([userId])
}

model ContestEntry {
  id                String   @id @default(cuid())
  contestId         String
  petId             String
  createdAt         DateTime @default(now())
  story             String?
  eliminatedAtRound Int?
  isEliminated      Boolean  @default(false)
  Contest           Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  Pet               Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([contestId, petId])
  @@index([contestId, isEliminated])
}

model CustomEmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  html      String
  prompt    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model EngagementLog {
  id            String   @id @default(cuid())
  targetUserId  String
  seedAccountId String
  petId         String
  action        String
  commentText   String?
  createdAt     DateTime @default(now())

  @@index([seedAccountId])
  @@index([targetUserId, createdAt])
}

model FlaggedComment {
  id           String     @id @default(cuid())
  commentId    String
  reason       String
  matchedWords String[]
  status       FlagStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime   @default(now())
  Comment      Comment    @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
}

model Follow {
  id                            String   @id @default(cuid())
  followerId                    String
  followingId                   String
  createdAt                     DateTime @default(now())
  User_Follow_followerIdToUser  User     @relation("Follow_followerIdToUser", fields: [followerId], references: [id], onDelete: Cascade)
  User_Follow_followingIdToUser User     @relation("Follow_followingIdToUser", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FollowBonusLog {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Nomination {
  id        String           @id @default(cuid())
  email     String
  name      String
  petName   String?
  contestId String
  status    NominationStatus @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime         @default(now())
  sentById  String
  Contest   Contest          @relation(fields: [contestId], references: [id], onDelete: Cascade)
  User      User             @relation(fields: [sentById], references: [id], onDelete: Cascade)

  @@unique([email, contestId])
  @@index([contestId])
  @@index([email])
  @@index([status])
}

model NominationSendJob {
  id          String   @id @default(cuid())
  contestId   String
  contestName String
  recipients  Json
  total       Int
  sent        Int      @default(0)
  failed      Int      @default(0)
  status      String   @default("running")
  startedAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  startedById String
  Contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [startedById], references: [id], onDelete: Cascade)

  @@index([startedById])
  @@index([status])
}

model Notification {
  id                                   String           @id @default(cuid())
  userId                               String
  type                                 NotificationType
  title                                String
  message                              String
  isRead                               Boolean          @default(false)
  linkUrl                              String?
  sourceUserId                         String?
  createdAt                            DateTime         @default(now())
  User_Notification_sourceUserIdToUser User?            @relation("Notification_sourceUserIdToUser", fields: [sourceUserId], references: [id])
  User_Notification_userIdToUser       User             @relation("Notification_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, isRead])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model Pet {
  id               String             @id @default(cuid())
  name             String             @db.VarChar(60)
  type             PetType
  breed            String?
  bio              String?            @db.VarChar(255)
  ownerName        String
  ownerFirstName   String?
  ownerLastName    String?
  address          String?
  city             String?
  state            String?
  zipCode          String?
  country          String?            @default("US")
  photos           String[]
  tags             String[]
  isActive         Boolean            @default(true)
  optInDesigns     Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  userId           String
  AnonymousVote    AnonymousVote[]
  Comment          Comment[]
  ContestEntry     ContestEntry[]
  User             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  PetWeeklyStats   PetWeeklyStats[]
  ProductDesign    ProductDesign[]
  ScheduledComment ScheduledComment[]
  ScheduledVote    ScheduledVote[]
  Vote             Vote[]

  @@index([breed])
  @@index([createdAt])
  @@index([state])
  @@index([type, isActive])
}

model PetWeeklyStats {
  id         String   @id @default(cuid())
  petId      String
  weekId     String
  totalVotes Int      @default(0)
  freeVotes  Int      @default(0)
  paidVotes  Int      @default(0)
  rank       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([petId, weekId])
  @@index([petId])
  @@index([weekId, totalVotes(sort: Desc)])
}

model PostComment {
  id              String            @id @default(cuid())
  postId          String
  userId          String
  content         String
  createdAt       DateTime          @default(now())
  UserPost        UserPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  User            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  PostCommentLike PostCommentLike[]

  @@index([postId, createdAt])
}

model PostCommentLike {
  id          String      @id @default(cuid())
  commentId   String
  userId      String
  createdAt   DateTime    @default(now())
  PostComment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  User        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  reaction  String   @default("HEART")
  UserPost  UserPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model Prize {
  id          String      @id @default(cuid())
  contestId   String
  placement   Int
  title       String
  description String?
  value       Int
  items       String[]
  status      PrizeStatus @default(PENDING)
  winnerId    String?
  awardedAt   DateTime?
  fulfilledAt DateTime?
  createdAt   DateTime    @default(now())
  Contest     Contest     @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, placement])
}

model ProductDesign {
  id            String          @id @default(cuid())
  petId         String
  theme         String
  aiImageUrl    String
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  Pet           Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)
  ProductMockup ProductMockup[]

  @@index([petId])
}

model ProductMockup {
  id            String         @id @default(cuid())
  designId      String
  productType   ProductType
  mockupUrl     String
  price         Int
  costBasis     Int
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  ProductDesign ProductDesign  @relation(fields: [designId], references: [id], onDelete: Cascade)
  ProductOrder  ProductOrder[]

  @@index([designId])
}

model ProductOrder {
  id              String        @id @default(cuid())
  userId          String
  mockupId        String
  quantity        Int           @default(1)
  size            String?
  totalAmount     Int
  stripePaymentId String?
  status          OrderStatus   @default(PENDING)
  trackingNumber  String?
  shippingAddress String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  ProductMockup   ProductMockup @relation(fields: [mockupId], references: [id])
  User            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Purchase {
  id                 String        @id @default(cuid())
  userId             String
  packageTier        PackageTier
  votes              Int
  amount             Int
  currency           String        @default("usd")
  stripePaymentId    String?       @unique
  stripeSessionId    String?       @unique
  status             PaymentStatus @default(PENDING)
  mealsProvided      Float         @default(0)
  mealRateAtPurchase Float         @default(10.0)
  createdAt          DateTime      @default(now())
  discountPct        Int           @default(0)
  isFirstTimeBuyer   Boolean       @default(false)
  originalAmount     Int           @default(0)
  User               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model ReEntryToken {
  id            String    @id @default(cuid())
  token         String    @unique
  userId        String
  petId         String
  fromContestId String
  toContestId   String
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model ScheduledComment {
  id                  String                 @id @default(cuid())
  petId               String
  engagementAccountId String
  scheduledFor        DateTime
  commentText         String                 @db.VarChar(255)
  status              ScheduledCommentStatus @default(PENDING)
  processedAt         DateTime?
  errorMessage        String?                @db.VarChar(500)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime
  User                User                   @relation(fields: [engagementAccountId], references: [id], onDelete: Cascade)
  Pet                 Pet                    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([engagementAccountId])
  @@index([petId])
  @@index([scheduledFor, status])
}

model ScheduledVote {
  id            String              @id @default(cuid())
  petId         String
  seedAccountId String
  votesAmount   Int                 @default(1)
  weekId        String
  scheduledFor  DateTime
  status        ScheduledVoteStatus @default(PENDING)
  processedAt   DateTime?
  errorMessage  String?             @db.VarChar(500)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime
  Pet           Pet                 @relation(fields: [petId], references: [id], onDelete: Cascade)
  User          User                @relation(fields: [seedAccountId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([scheduledFor, status])
  @@index([seedAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShelterPartner {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  website     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ShelterPost {
  id            String          @id @default(cuid())
  title         String?
  featuredImage String?
  content       String?
  photos        String[]
  caption       String?
  videoUrl      String?
  tags          String[]
  type          ShelterPostType @default(UPDATE)
  location      String?
  contestId     String?
  authorId      String
  isPublished   Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now())
  User          User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  Contest       Contest?        @relation(fields: [contestId], references: [id])

  @@index([isPublished, createdAt])
  @@index([type])
}

model Story {
  id        String      @id @default(cuid())
  userId    String
  mediaUrl  String
  mediaType String      @default("image")
  caption   String?     @db.VarChar(200)
  createdAt DateTime    @default(now())
  expiresAt DateTime
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     StoryLike[]
  views     StoryView[]

  @@index([expiresAt])
  @@index([userId, expiresAt])
}

model StoryLike {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
}

model User {
  id                                           String                 @id @default(cuid())
  name                                         String?
  email                                        String?                @unique
  emailVerified                                DateTime?
  image                                        String?
  password                                     String?
  role                                         UserRole               @default(USER)
  city                                         String?
  state                                        String?
  country                                      String?
  zipCode                                      String?
  createdAt                                    DateTime               @default(now())
  updatedAt                                    DateTime
  freeVotesRemaining                           Int                    @default(5)
  lastFreeVoteReset                            DateTime               @default(now())
  votingStreak                                 Int                    @default(0)
  lastVotedWeek                                String?
  paidVoteBalance                              Int                    @default(0)
  lastFreeVoteReminderWeek                     String?
  lastVoteDateStr                              String?
  votingStreakDays                             Int                    @default(0)
  Account                                      Account[]
  ChatConversation                             ChatConversation[]
  Comment                                      Comment[]
  CommentLike                                  CommentLike[]
  ContestEmailLog                              ContestEmailLog[]
  Follow_Follow_followerIdToUser               Follow[]               @relation("Follow_followerIdToUser")
  Follow_Follow_followingIdToUser              Follow[]               @relation("Follow_followingIdToUser")
  FollowBonusLog                               FollowBonusLog[]
  Nomination                                   Nomination[]
  NominationSendJob                            NominationSendJob[]
  Notification_Notification_sourceUserIdToUser Notification[]         @relation("Notification_sourceUserIdToUser")
  Notification_Notification_userIdToUser       Notification[]         @relation("Notification_userIdToUser")
  PasswordResetToken                           PasswordResetToken[]
  Pet                                          Pet[]
  PostComment                                  PostComment[]
  PostCommentLike                              PostCommentLike[]
  PostLike                                     PostLike[]
  ProductOrder                                 ProductOrder[]
  Purchase                                     Purchase[]
  ScheduledComment                             ScheduledComment[]
  ScheduledVote                                ScheduledVote[]
  Session                                      Session[]
  ShelterPost                                  ShelterPost[]
  Story                                        Story[]
  storyLikes                                   StoryLike[]
  storyViews                                   StoryView[]
  UserBadge                                    UserBadge[]
  UserNotificationPrefs                        UserNotificationPrefs?
  UserPost                                     UserPost[]
  Vote                                         Vote[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  Badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserNotificationPrefs {
  id                  String  @id @default(cuid())
  userId              String  @unique
  voteAlerts          Boolean @default(true)
  commentAlerts       Boolean @default(true)
  designAlerts        Boolean @default(true)
  weeklyDigest        Boolean @default(true)
  freeVoteReminder    Boolean @default(true)
  contestAlerts       Boolean @default(true)
  maxVoteAlertsPerDay Int     @default(5)
  User                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPost {
  id          String        @id @default(cuid())
  content     String
  imageUrl    String?
  createdAt   DateTime      @default(now())
  userId      String
  PostComment PostComment[]
  PostLike    PostLike[]
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vote {
  id          String   @id @default(cuid())
  petId       String
  userId      String
  voteType    VoteType
  quantity    Int      @default(1)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  contestWeek String
  Pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contestWeek])
  @@index([createdAt])
  @@index([petId, contestWeek])
  @@index([userId, contestWeek])
}

model VoteEmailCooldown {
  id           String   @id @default(cuid())
  petId        String
  ownerId      String
  lastSentAt   DateTime @default(now())
  pendingCount Int      @default(0)

  @@unique([petId, ownerId])
  @@index([ownerId])
  @@index([petId])
}

enum BadgeCategory {
  VOTING
  SOCIAL
  PETS
  STREAK
  COMMUNITY
}

enum BookingStatus {
  PENDING
